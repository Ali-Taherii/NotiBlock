{
    "Serilog": {
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft.AspNetCore": "Warning",
                "Microsoft.EntityFrameworkCore": "Warning"
            }
        },
        "WriteTo": [
            {
                "Name": "Console"
            },
            {
                "Name": "File",
                "Args": {
                    "path": "logs/notiblock-.txt",
                    "rollingInterval": "Day",
                    "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
                }
            }
        ]
    },
    "JwtSettings": {
        "Key": "SET_VIA_ENVIRONMENT_VARIABLE_JwtSettings__Key",
        "Issuer": "NotiBlockAPI",
        "Audience": "NotiBlockUsers",
        "ExpirationMinutes": 480,
        "RefreshTokenExpirationDays": 7
    },
    "ConnectionStrings": {
        "DefaultConnection": "SET_VIA_ENVIRONMENT_VARIABLE_ConnectionStrings__DefaultConnection"
    },
    "Blockchain": {
        "RpcUrl": "https://rpc-mumbai.maticvigil.com",
        "PrivateKey": "SET_VIA_ENVIRONMENT_VARIABLE_Blockchain__PrivateKey",
        "ContractAddress": "SET_VIA_ENVIRONMENT_VARIABLE_Blockchain__ContractAddress"
    },
    "AllowedHosts": "*",
    "CorsSettings": {
        "AllowedOrigin": "http://localhost:5173"
    }
}