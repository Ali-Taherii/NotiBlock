# ===========================
# Database Configuration
# ===========================
DB_PASSWORD=your_secure_db_password_here

# ===========================
# JWT Configuration
# ===========================
# Must be at least 32 characters for production
JWT_KEY=your-super-secret-jwt-key-change-this-in-production-at-least-32-characters

# ===========================
# Blockchain Configuration
# ===========================
# RPC URL for Polygon Mumbai testnet (or Sepolia for frontend)
BLOCKCHAIN_RPC_URL=https://rpc-mumbai.maticvigil.com

# Private key for blockchain transactions (without 0x prefix, in hex)
BLOCKCHAIN_PRIVATE_KEY=

# Smart contract address for NotiBLock recall registry
BLOCKCHAIN_CONTRACT_ADDRESS=0x0f41904d1F083989B70BD223FCa6feD911002aFD

# ===========================
# API & CORS Configuration
# ===========================
# CORS allowed origin - used by backend to allow frontend requests
CORS_ORIGIN=http://localhost

# ===========================
# ASP.NET Environment
# ===========================
# Development, Staging, or Production
ASPNETCORE_ENVIRONMENT=Production

# ===========================
# Frontend API Base URL
# ===========================
# Backend API URL that frontend will connect to
VITE_API_BASE_URL=http://localhost:5271
